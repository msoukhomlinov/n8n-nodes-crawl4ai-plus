{
  "name": "n8n-nodes-crawl4ai-plus",
  "version": "5.0.1",
  "description": "n8n nodes for Crawl4AI v0.8.0 web crawler and data extraction with enhanced features",
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "crawl4ai",
    "web-crawler",
    "data-extraction",
    "scraping",
    "regex-extraction",
    "llm-extraction"
  ],
  "license": "MIT",
  "homepage": "https://github.com/msoukhomlinov/n8n-nodes-crawl4ai-plus",
  "author": { "name": "Max Soukhomlinov" },
  "repository": {
    "type": "git",
    "url": "https://github.com/msoukhomlinov/n8n-nodes-crawl4ai-plus.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "format": "prettier --write \"nodes/**/*.ts\" \"credentials/**/*.ts\"",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "preinstall": "npx only-allow pnpm",
    "prepublishOnly": "pnpm run build && pnpm run lint"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": ["dist/credentials/Crawl4aiApi.credentials.js"],
    "nodes": [
      "dist/nodes/Crawl4aiPlus/Crawl4aiPlus.node.js",
      "dist/nodes/Crawl4aiPlusAdvanced/Crawl4aiPlusAdvanced.node.js"
    ],
    "strict": false
  },
  "devDependencies": {
    "@n8n/node-cli": ">=0.17.0",
    "eslint": "^9.0.0",
    "prettier": "^3.1.0",
    "typescript": "~5.5.4"
  },
  "peerDependencies": { "n8n-workflow": ">=1.60.0" },
  "dependencies": { "axios": "^1.7.9" }
}
